{
  "name": "Releases",
  "slug": "releases",
  "defaultEnabled": true,
  "description": "Unified release lifecycle: planning, execution tracking, and delivery readiness",
  "icon": "rocket",
  "order": 3,
  "client": {
    "entry": "./client/index.js",
    "navItems": [
      { "id": "registry", "label": "Manage", "icon": "Database", "requireRole": "release-manager" },
      { "id": "plan", "label": "Plan", "icon": "ClipboardList", "default": true },
      { "id": "execute", "label": "Execute", "icon": "GitBranch" },
      { "id": "deliver", "label": "Deliver", "icon": "Rocket" },
      { "id": "reports", "label": "Reports", "icon": "BarChart3" },
      { "id": "audit", "label": "Audit", "icon": "History", "requireRole": "release-manager" }
    ],
    "settingsComponent": "./client/components/ReleasesSettings.vue",
    "hiddenRoutes": {
      "feature-detail": "execute"
    }
  },
  "server": {
    "entry": "./server/index.js"
  },
  "secrets": {
    "platform": ["jira"],
    "module": [
      {
        "key": "PRODUCT_PAGES_CLIENT_ID",
        "description": "OAuth client ID for Product Pages (production)",
        "required": false,
        "group": "product-pages-auth"
      },
      {
        "key": "PRODUCT_PAGES_CLIENT_SECRET",
        "description": "OAuth client secret for Product Pages",
        "required": false,
        "group": "product-pages-auth"
      },
      {
        "key": "PRODUCT_PAGES_TOKEN",
        "description": "Personal bearer token for Product Pages (local dev fallback)",
        "required": false,
        "group": "product-pages-auth",
        "exclusive": true
      },
      {
        "key": "FEATURE_TRAFFIC_GITLAB_TOKEN",
        "description": "GitLab PAT for CI artifact fetching (overrides GITLAB_TOKEN)",
        "required": false
      },
      {
        "key": "SMARTSHEET_API_TOKEN",
        "description": "SmartSheet API token for release discovery",
        "required": false
      }
    ]
  },
  "export": {
    "files": [
      { "path": "releases/registry.json", "notes": "Canonical release registry" },
      { "path": "releases/execution/index.json", "notes": "Feature index with summary metrics" },
      { "path": "releases/execution/features/*.json", "notes": "Per-feature detail files" }
    ]
  }
}
